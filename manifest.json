{
	"manifest_version": 2,
	"name": "ffifapi",
	"version": "1.5",
	"description": "Firefox Interface API Extension over Websockets",

	"browser_specific_settings": {
		"gecko": {
			"id": "{d7bf81a7-d089-43a3-9268-6360baa1326c}",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},

	"background": {
		"scripts": [
			"addon/background.js",
			"addon/comm.js",
			"addon/handler.js",
			"addon/browser.js"
		]
	},
	"permissions": [
		"tabs",
		"activeTab",
		"cookies",
		"contextualIdentities",
		"alarms"
	],
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": [
				"addon/content.js"
			]
		}
	]
}